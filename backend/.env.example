# ===========================================================================
# Konfigurasi Backend (Sistem Pakar Bimbingan Jurusan)
# Salin file ini menjadi ".env" lalu sesuaikan nilainya.
#   PowerShell : Copy-Item .env.example .env
# ===========================================================================

# --- Database (MySQL) ------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sistem_pakar

# --- Keamanan / JWT --------------------------------------------------------
# WAJIB diisi. Server menolak start jika kosong.
# Buat string acak panjang, mis. (PowerShell):
#   [Convert]::ToBase64String((1..48 | % { Get-Random -Max 256 }))
JWT_SECRET=

# Masa berlaku token (format Go duration: 24h, 30m, 168h, dst.)
JWT_ACCESS_EXPIRE=24h
JWT_REFRESH_EXPIRE=168h

# Set true HANYA di produksi (HTTPS). Untuk dev lokal HTTP biarkan false.
COOKIE_SECURE=false

# --- Server ----------------------------------------------------------------
SERVER_PORT=8080

# Daftar origin yang diizinkan CORS, pisahkan dengan koma jika lebih dari satu.
# Contoh: http://localhost:3000,https://app.contoh.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
