# ===========================================================================
# Konfigurasi Frontend (Next.js)
# Salin file ini menjadi ".env.local" lalu sesuaikan nilainya.
#   PowerShell : Copy-Item .env.example .env.local
# ===========================================================================

# URL dasar API backend (harus menyertakan akhiran /api).
# Variabel berprefix NEXT_PUBLIC_ akan ter-bundle ke sisi klien.
NEXT_PUBLIC_API_URL=http://localhost:8080/api
